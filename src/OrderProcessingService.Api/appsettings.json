{
  "Urls": "http://+:8080",
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "order_processing"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "ProductCacheTtlSeconds": 60,
    "OrderCacheTtlSeconds": 30
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "orders.events",
    "OrderCreatedRoutingKey": "order.created"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
